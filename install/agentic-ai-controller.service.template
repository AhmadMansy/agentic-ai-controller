# systemd user unit template for agentic-ai-controller bridge (Linux).
# install.sh substitutes {{PYTHON_BIN}}, {{BRIDGE_SCRIPT}}, {{HTTP_PORT}}.
# Installed to ~/.config/systemd/user/agentic-ai-controller.service
#
# Commands:
#   systemctl --user status  agentic-ai-controller
#   systemctl --user restart agentic-ai-controller
#   journalctl --user -u agentic-ai-controller -f

[Unit]
Description=agentic-ai-controller Arduino bridge
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart={{PYTHON_BIN}} {{BRIDGE_SCRIPT}} --http-port {{HTTP_PORT}}
Restart=on-failure
RestartSec=5
# Serial devices need dialout on most distros — the user must already be in it.
# (Run `sudo usermod -aG dialout $USER` if the bridge cannot open the port.)

[Install]
WantedBy=default.target
